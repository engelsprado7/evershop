# Copy to .env and fill in values. Do not commit .env.

# --- Local development (e.g. Postgres in Docker) ---
# DB_HOST="localhost"
# DB_PORT="5433"
# DB_NAME="evershop"
# DB_USER="postgres"
# DB_PASSWORD="admin"
# DB_SSLMODE="disable"

# --- Azure PostgreSQL Flexible Server (production) ---
# Set these in Azure Web App → Configuration → Application settings
DB_HOST="yourserver.postgres.database.azure.com"
DB_PORT="5432"
DB_NAME="evershop"
DB_USER="youruser"
DB_PASSWORD="your-secure-password"
DB_SSLMODE="require"
